# Target/source builds and generated artifacts.
targets/**/source/
targets/**/distfiles/
targets/**/build*/
targets/**/out/
targets/**/*.o
targets/**/*.a
targets/**/*.so
targets/**/*.dylib
targets/**/*.exe

# Harness builds.
harnesses/**/build*/
harnesses/**/out/
harnesses/**/*.o
harnesses/**/*.a
harnesses/**/*.so
harnesses/**/*.dylib
harnesses/**/*.exe

# PoC-local target copies and builds.
pocs/**/build*/
pocs/**/xpdf-*-build*/
pocs/**/xpdf-*-src/
pocs/**/__pycache__/
pocs/**/*.pyc
pocs/**/*.pyo
pocs/cve-2020-25725/*.ps

# Fuzzing outputs. Keep human-authored records and repro scripts tracked.
experiments/**/corpus/
experiments/**/crashes/
experiments/**/hangs/
experiments/**/queue/
experiments/**/artifacts/
experiments/**/afl-out/
experiments/**/out/
experiments/**/seeds/
experiments/**/*.log
experiments/**/*.pid
experiments/**/*.bin
experiments/**/reached-funcs.txt
!experiments/**/README.md
!experiments/**/metadata.md
!experiments/**/repro.sh
!experiments/**/run.sh
!experiments/**/run-summary/

# Fuzzing baselines: same regenerable outputs as experiments/.
baselines/**/corpus/
baselines/**/crashes/
baselines/**/hangs/
baselines/**/queue/
baselines/**/artifacts/
baselines/**/afl-out/
baselines/**/out/
baselines/**/seeds/
baselines/**/*.log
baselines/**/*.pid
baselines/**/*.bin
baselines/**/reached-funcs.txt
!baselines/**/README.md
!baselines/**/metadata.md
!baselines/**/repro.sh
!baselines/**/run.sh
!baselines/**/run-summary/

# Crash buckets can contain large generated inputs; add metadata/repro files first.
crashes/**/*.pdf
crashes/**/*.bin
crashes/**/*.proto
!crashes/**/README.md
!crashes/**/metadata.md
!crashes/**/repro.sh

# Thesis working tree is a machine-local scratch area (vendored xpdf source +
# schema build trees); it is not committed from any machine.
thesis/
